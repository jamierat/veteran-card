# ── Server ────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# Staff PIN - staff enter this to verify vets and redeem pints. CHANGE THIS.
STAFF_CODE=SALUTE

# The military discount shown on the pass and the staff screen. Set your real number.
MILITARY_DISCOUNT_LABEL=10% OFF

# Brewery timezone - anchors the "one pint per calendar month" rule.
BREWERY_TZ=America/New_York

# ── Apple Wallet Pass Signing ─────────────────────────────
# Reuses the SAME Apple Pass Type ID + cert as the lunch punchcard.
TEAM_ID=83JDA44VDE
PASS_TYPE_ID=pass.com.bullfrogcreekbrewing.lunchcard

# ── Live pass updates (optional but recommended) ──────────
# HTTPS URL of THIS app (your Railway domain, or ngrok for local testing).
# When set, passes auto-update on the customer's phone after verify/redeem.
# WEB_SERVICE_URL=https://your-salutes-app.up.railway.app
# APN_PRODUCTION=true

# On Railway, instead of the certs/ files you can paste base64 of each PEM:
# SIGNER_CERT_B64=...
# SIGNER_KEY_B64=...
# WWDR_CERT_B64=...
